#!/bin/bash
# ============================================================
# env.sh - Environment configuration for cross-tenant blob sync demo
# Copy this file to env.sh and fill in the values below.
#   cp env.sh.example env.sh
# ============================================================

# ---------- Tenant A (Source: ADF + Blob-A) ----------
export TENANT_A_ID=""              # Tenant A directory (tenant) ID
export SUB_A_ID=""                 # Subscription ID under Tenant A
export RG_A="rg-blob-sync-a"
export LOCATION_A="eastasia"
export STORAGE_A=""                # Must be globally unique, 3-24 chars, lowercase+numbers only
export CONTAINER_A="source-data"
export ADF_NAME="adf-blob-sync-demo"

# ---------- Tenant B (Destination: Blob-B) ----------
export TENANT_B_ID=""              # Tenant B directory (tenant) ID
export SUB_B_ID=""                 # Subscription ID under Tenant B
export RG_B="rg-blob-sync-b"
export LOCATION_B="eastasia"
export STORAGE_B=""                # Must be globally unique
export CONTAINER_B="dest-data"

# ---------- Service Principal (created in Tenant B for cross-tenant access) ----------
export SP_NAME="sp-adf-cross-tenant"
# These will be populated automatically by 02-setup-tenant-b.sh
export SP_APP_ID=""
export SP_SECRET=""
export SP_OBJECT_ID=""
